{
  "manifest_version": 3,
  "name": "Gaze",
  "description": "Track distraction time without blocking your flow.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "idle"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Gaze",
    "default_popup": "src/popup/index.html"
  },
  "options_page": "src/settings/index.html",
  "web_accessible_resources": [
    {
      "resources": ["src/dashboard/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
